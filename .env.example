# School portal (Entab CampusCare10X) credentials
SCHOOL_BASE_URL=https://entab.online/HISSJR
SCHOOL_USER_ID=
SCHOOL_PASSWORD=

# Which channel delivers notifications: "telegram" (default) or "whatsapp"
NOTIFICATION_CHANNEL=telegram

# Required if NOTIFICATION_CHANNEL=telegram. Create the bot via @BotFather,
# then message the bot once and fetch your chat_id from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Required if NOTIFICATION_CHANNEL=whatsapp (via Twilio's WhatsApp Sandbox -
# see README for setup). TWILIO_WHATSAPP_FROM defaults to Twilio's shared
# sandbox number and only needs overriding once you have your own WhatsApp Sender.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_TO_NUMBER=

# Which AI provider categorizes/summarizes the daily log PDF: "anthropic" (default) or "gemini"
AI_PROVIDER=anthropic

# Required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Required if AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# How to deliver today's Circulars (from ParentCircular): "summary" (default,
# AI-summarized text) or "raw" (the portal's own circular text as-is, plus the
# original PDF sent as a Telegram document if the circular has one attached)
CIRCULAR_DELIVERY_MODE=summary

# Optional: override the date to process (DD/MM/YYYY, matching the portal's
# own date format), for local testing/backfill. Defaults to "today" in Asia/Kolkata.
TARGET_DATE=
