# School portal (Entab CampusCare10X) credentials
SCHOOL_BASE_URL=https://entab.online/HISSJR
SCHOOL_USER_ID=
SCHOOL_PASSWORD=

# Telegram bot (create via @BotFather, then message the bot once and fetch
# your chat_id from https://api.telegram.org/bot<token>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic API key for categorizing/summarizing the daily log PDF
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: override the date to process (DD/MM/YYYY, matching the portal's
# own date format), for local testing/backfill. Defaults to "today" in Asia/Kolkata.
TARGET_DATE=
